  monthlyPrice    Float    @default(0)
  annualPrice     Float?
  currency        String   @default("USD")
  
  // Plan features
  features        String?  @db.Text // JSON array of feature strings
  limitations     String?  @db.Text // JSON array of limitations
  
  // Plan tier and order
  tier            String   @default("basic") // free, basic, pro, enterprise
  order           Int      @default(0)
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  
  // Billing config
  billingCycle    String   @default("monthly") // monthly, annual, lifetime
  trialDays       Int      @default(0)
  
  // Limits & quotas
  metadata        Json?    // Custom limits, feature flags, etc.
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?
  
  subscriptions   UserSubscription[]
  
  @@index([slug])
  @@index([tier])
  @@index([isActive])
  @@index([order])
}

/// *
///  * UserSubscription - User's active subscription
///  * One active subscription per user
///  * Tracks current plan, renewal date, and status
model UserSubscription {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation("UserSubscription", fields: [userId], references: [id], onDelete: Cascade)
  
  planId          String
  plan            PricingPlan @relation(fields: [planId], references: [id])
  
  // Subscription dates
  startDate       DateTime @default(now())
  endDate         DateTime? // Null for active, or set for cancellation
  renewalDate     DateTime?
  autoRenew       Boolean  @default(true)
  
  // Status
  status          SubscriptionStatus @default(ACTIVE)
  
  // Payment tracking
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?
  lastPaymentId   String?
  
  // Trial tracking
  trialEndDate    DateTime?
  
  // Downgrade scheduling
  scheduledDowngradeAt DateTime? // Date when downgrade will occur (after current period ends)
  scheduledDowngradePlanId String? // Plan to downgrade to
  
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  history         SubscriptionHistory[]
  invoices        Invoice[]
  
  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([renewalDate])
  @@index([createdAt])
}

/// *
///  * SubscriptionHistory - Track all subscription changes
///  * Records when users upgrade/downgrade/cancel
///  * Used for analytics and downgrade scheduling
model SubscriptionHistory {
  id              String   @id @default(cuid())
  subscriptionId  String
  subscription    UserSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  userId          String
  
  // Change details
  actionType      SubscriptionAction // UPGRADE, DOWNGRADE, RENEW, CANCEL, REACTIVATE
  fromPlanId      String?
  toPlanId        String?
  
  // Pricing at time of change
  amount          Float
  currency        String  @default("USD")
  
  // For downgrades - record when it will take effect
  effectiveDate   DateTime? // When downgrade/cancellation takes effect
  
  // Payment/invoice tracking
  invoiceId       String?
  paymentId       String?
  
  reason          String? @db.Text // Why they downgraded/cancelled
  notes           String? @db.Text
  
  createdAt       DateTime @default(now())
  
  @@index([subscriptionId])
  @@index([userId])
  @@index([actionType])
  @@index([createdAt])
}

/// *
///  * Invoice - Track all invoices and payments
///  * One invoice per subscription renewal
///  * Can have multiple payment attempts
model Invoice {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("Invoices", fields: [userId], references: [id], onDelete: Cascade)
  
  subscriptionId  String?
  subscription    UserSubscription? @relation(fields: [subscriptionId], references: [id])
  
  // Invoice details
  invoiceNumber   String   @unique
  amount          Float
  currency        String   @default("USD")
  
  // Dates
  issuedAt        DateTime @default(now())
  dueDate         DateTime
  paidAt          DateTime?
  
  // Status
  status          InvoiceStatus @default(PENDING)
  
  // Period
  billingPeriodStart DateTime
  billingPeriodEnd DateTime
  
  // Payment tracking
  paymentId       String?
  paymentMethod   String? // card, bank_transfer, etc.
  
  // Metadata
  description     String?
  notes           String? @db.Text
  metadata        Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([invoiceNumber])
  @@index([issuedAt])
}

enum SubscriptionStatus {
  ACTIVE          // User has active subscription
  TRIAL           // In trial period
  PAST_DUE        // Payment overdue
  PAUSED          // Temporarily paused
  CANCELLED       // Cancelled by user
  EXPIRED         // Subscription expired
  PENDING_RENEWAL // Waiting for next renewal
}

enum SubscriptionAction {
  CREATED         // New subscription created
  UPGRADED        // Upgraded to higher plan
  DOWNGRADED      // Downgraded to lower plan
  RENEWED         // Subscription renewed
  CANCELLED       // Subscription cancelled
  REACTIVATED     // Cancelled sub reactivated
  TRIAL_STARTED   // Trial started
  TRIAL_ENDED     // Trial ended
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

/// *
///  * ChatSession - AI Chat conversation sessions
///  * Stores chat sessions for AI assistant conversations
///  * Each session represents a conversation thread
model ChatSession {
  id          String       @id @default(cuid())
  title       String       @default("New Chat")
  userId      String
  user        User         @relation("ChatSessions", fields: [userId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId])
  @@index([createdAt])
}

/// *
///  * ChatMessage - Individual messages in chat sessions
///  * Stores user and AI messages within chat sessions
///  * Supports streaming and different message types
model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        String      // "user" or "assistant"
  content     String      @db.Text
  createdAt   DateTime    @default(now())

  @@index([sessionId])
  @@index([createdAt])
}