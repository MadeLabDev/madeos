generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  username               String?                 @unique
  name                   String?
  password               String?
  image                  String?
  emailVerified          DateTime?
  activationToken        String?                 @unique
  activationTokenExpiry  DateTime?
  isActive               Boolean                 @default(false)
  resetToken             String?                 @unique
  resetTokenExpiry       DateTime?
  twoFactorEnabled       Boolean                 @default(false)
  twoFactorSecret        String?
  backupCodes            String?                 @db.Text
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  createdBy              String?
  updatedBy              String?
  accounts               Account[]
  assignedKnowledge      KnowledgeAssignedUser[]
  knowledgeEmailLogs     KnowledgeEmailLog[]
  uploadedMedia          Media[]
  sessions               Session[]
  userGroupMembers       UserGroupMember[]
  userProfile            UserProfile?
  userRoles              UserRole[]
  eventsCreated          Event[]                 @relation("EventCreatedBy")
  eventsUpdated          Event[]                 @relation("EventUpdatedBy")
  payments               Payment[]
  tickets                Ticket[]
  registrations          Registration[]
  registrationsCheckedIn Registration[]          @relation("RegistrationCheckedInBy")
  checkIns               CheckIn[]
  trainingRegistrations  TrainingRegistration[]
  trainingRegistrationsCheckedIn TrainingRegistration[] @relation("TrainingRegistrationCheckedInBy")
  trainingCheckIns       TrainingCheckIn[]
  trainingEngagementsAsInstructor TrainingEngagement[] @relation("TrainingEngagementInstructor")
  trainingEngagementsAsCoordinator TrainingEngagement[] @relation("TrainingEngagementCoordinator")
  trainingEngagementsAsRequestedBy TrainingEngagement[] @relation("TrainingEngagementRequestedBy")
  opportunitiesOwned     Opportunity[]           @relation("OpportunityOwner")
  marketingCampaignsCreated MarketingCampaign[]   @relation("MarketingCampaignCreatedBy")
  marketingCampaignsUpdated MarketingCampaign[]   @relation("MarketingCampaignUpdatedBy")
  campaignEmailsSent      CampaignEmail[]        @relation("CampaignEmailSentBy")
  campaignTemplatesCreated CampaignTemplate[]     @relation("CampaignTemplateCreatedBy")
  campaignTemplatesUpdated CampaignTemplate[]     @relation("CampaignTemplateUpdatedBy")
  eventMicrositesCreated  EventMicrosite[]       @relation("EventMicrositeCreatedBy")
  eventMicrositesUpdated  EventMicrosite[]       @relation("EventMicrositeUpdatedBy")
  sponsorMaterialsCreated SponsorMaterial[]      @relation("SponsorMaterialCreatedBy")
  sponsorMaterialsUpdated SponsorMaterial[]      @relation("SponsorMaterialUpdatedBy")
  sponsorMaterialsApproved SponsorMaterial[]      @relation("SponsorMaterialApprovedBy")
  vectorSearchLogs        VectorSearchLog[]      @relation("VectorSearchLogs")
  ragSessions             RAGSession[]           @relation("RAGSessions")
  ragFeedback             RAGFeedback[]          @relation("RAGFeedback")
  chatSessions            ChatSession[]          @relation("ChatSessions")
  subscription            UserSubscription?      @relation("UserSubscription")
  invoices                Invoice[]              @relation("Invoices")

  @@index([email])
  @@index([username])
}

/// *
///  * UserGroup - Groups of users for organization and bulk operations
///  * Admin/Manager can create groups and assign users to them
model UserGroup {
  id                String                   @id @default(cuid())
  name              String                   @unique
  description       String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  createdBy         String?
  updatedBy         String?
  assignedKnowledge KnowledgeAssignedGroup[]
  members           UserGroupMember[]

  @@index([name])
  @@index([createdAt])
}

/// *
///  * UserGroupMember - Junction table for User-Group many-to-many relationship
///  * Links users to groups with assignment metadata
model UserGroupMember {
  id         String    @id @default(cuid())
  userId     String
  groupId    String
  assignedAt DateTime  @default(now())
  assignedBy String?
  group      UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([groupId])
  @@index([assignedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  displayName     String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@index([name])
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Module {
  id              String           @id @default(cuid())
  name            String           @unique
  displayName     String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@index([name])
}

model Permission {
  id              String           @id @default(cuid())
  action          String           @unique
  displayName     String
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@index([action])
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  moduleId     String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module       Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId, permissionId])
  @@index([roleId])
  @@index([moduleId])
  @@index([permissionId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  value     String   @db.Text
  entity    String
  entityId  String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

model Media {
  id           String   @id @default(cuid())
  name         String
  url          String
  type         String
  size         Int
  visibility   String   @default("PRIVATE")
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  uploadedBy   User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  // Entity linking for attachments
  entityType String?
  entityId   String?
  events     Event[]
  eventMicrosites EventMicrosite[]
  sponsorMaterials SponsorMaterial[]

  @@index([uploadedById])
  @@index([visibility])
  @@index([createdAt])
  @@index([entityType, entityId])
}

model Settings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([createdAt])
}

/// *
///  * Customer - Parent/Main customer account
///  * Represents the main account holder (e.g., Company A)
///  * Can have multiple child locations/branches
model Customer {
  id               String          @id @default(cuid())
  companyName      String
  email            String          @unique
  phone            String?
  website          String?
  address          String
  city             String
  state            String
  zipCode          String
  country          String          @default("USA")
  contactName      String
  contactTitle     String?
  contactEmail     String?
  contactPhone     String?
  type             String          @default("customer")
  taxId            String?
  parentId         String?
  discountPercent  Float           @default(0)
  paymentTermsDays Int             @default(30)
  creditLimit      Float?
  isActive         Boolean         @default(true)
  notes            String?
  metaData         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdBy        String?
  updatedBy        String?
  parent           Customer?       @relation("CustomerLocations", fields: [parentId], references: [id])
  locations        Customer[]      @relation("CustomerLocations")
  contacts         Contact[]
  opportunities    Opportunity[]
  engagements      Engagement[]
  designProjects   DesignProject[] @relation("DesignProjects")
  trainingEngagements TrainingEngagement[] // For training engagements

  @@index([email])
  @@index([phone])
  @@index([parentId])
  @@index([companyName])
  @@index([isActive])
  @@index([createdAt])
}

/// *
///  * ModuleType - Định nghĩa các loại module (ADMIN quản lý)
///  * Sử dụng để tạo dynamic fields cho các entity type khác nhau
///  * Ví dụ: blog, knowngle, product, order, profile...
///  * Mỗi module type có fieldSchema JSON định nghĩa cấu trúc fields
model ModuleType {
  id              String           @id @default(cuid())
  key             String           @unique
  system          String           @default("profile")
  name            String
  description     String?
  fieldSchema     Json
  lockedFields    Json
  isEnabled       Boolean          @default(true)
  order           Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?
  updatedBy       String?
  moduleInstances ModuleInstance[]

  @@index([system])
  @@index([key])
  @@index([isEnabled])
  @@index([createdAt])
}

/// *
///  * ModuleInstance - Instances of module metadata
///  * Mỗi bản ghi metadata cho một entity cụ thể
///  * Ví dụ: Meta cho một bài blog cụ thể
model ModuleInstance {
  id           String     @id @default(cuid())
  moduleTypeId String
  entityId     String
  entityName   String
  fieldValues  Json
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdBy    String?
  updatedBy    String?
  moduleType   ModuleType @relation(fields: [moduleTypeId], references: [id], onDelete: Cascade)

  @@unique([moduleTypeId, entityId])
  @@index([moduleTypeId])
  @@index([entityId])
  @@index([entityName])
  @@index([isActive])
  @@index([createdAt])
}

/// *
///  * ExternalFormData - Store external form submissions
///  * External websites submit form data to our API with a unique key
///  * We store all submissions indexed by key for easy retrieval
///  * 
///  * Example:
///  * - External form at: https://external-site.com/survey
///  * - Submits to: POST /api/form-data/submit
///  * - Payload: { key: "phc2025_after_survey", field: [firstName, lastName, email, formData] }
///  * - Retrieve: GET /api/form-data/retrieve?key=phc2025_after_survey
model ExternalFormData {
  id        String   @id @default(cuid())
  key       String
  data      Json
  ipAddress String?
  userAgent String?
  referer   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([createdAt])
  @@map("FormData")
}

/// *
///  * UserProfile - User's public/private profile with draggable modules
///  * Mỗi user có một profile duy nhất
///  * Profile chứa multiple modules (work experience, education, skills, etc)
///  * Modules có thể drag-drop, sort, show/hide
model UserProfile {
  id              String              @id @default(cuid())
  userId          String              @unique
  metaData        Json
  isPublic        Boolean             @default(false)
  slug            String?             @unique
  metaTitle       String?
  metaDescription String?
  viewCount       Int                 @default(0)
  lastViewedAt    DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  modules         UserProfileModule[]
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([slug])
  @@index([isPublic])
  @@index([createdAt])
  @@map("UserProfiles")
}

/// *
///  * UserProfileModule - Instances of modules in user profile
///  * Mỗi module là một section trong profile (e.g., Work Experience, Education, Skills)
///  * Modules có thể được arrange trong 2 columns, drag-drop, sort, show/hide
model UserProfileModule {
  id           String      @id @default(cuid())
  profileId    String
  moduleTypeId String?
  data         Json
  order        Int         @default(0)
  column       Int         @default(1)
  isVisible    Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  profile      UserProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([order])
  @@index([column])
  @@map("UserProfileModules")
}

/// *
///  * KnowledgeCategory - Categories for knowledge articles
///  * Gốc cho việc phân loại các bài viết knowledge
model KnowledgeCategory {
  id          String                           @id @default(cuid())
  name        String                           @unique
  slug        String                           @unique
  description String?
  color       String?                          @default("#000000")
  icon        String?
  order       Int                              @default(0)
  createdAt   DateTime                         @default(now())
  updatedAt   DateTime                         @updatedAt
  knowledge   KnowledgeCategoriesOnKnowledge[]

  @@index([slug])
  @@index([order])
  @@map("KnowledgeCategories")
}

/// *
///  * KnowledgeTag - Tags for knowledge articles (flexible tagging system)
///  * Tags giúp người dùng tìm kiếm và filter bài viết
model KnowledgeTag {
  id                String                     @id @default(cuid())
  name              String                     @unique
  slug              String                     @unique
  color             String?                    @default("#666666")
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  knowledgeArticles KnowledgeTagsOnKnowledge[]

  @@index([slug])
  @@map("KnowledgeTags")
}

/// *
///  * Knowledge - Main knowledge base article model
///  * Lưu trữ các bài viết blog/wiki với đầy đủ metadata
model Knowledge {
  id             String                           @id @default(cuid())
  title          String
  slug           String                           @unique
  content        String                           @db.Text
  excerpt        String?                          @db.Text
  thumbnail      String?                          @db.Text
  type           String                           @default("knowledge")
  visibility     String                           @default("public")
  viewCount      Int                              @default(0)
  isPublished    Boolean                          @default(false)
  publishedAt    DateTime?
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt
  metaData       Json?
  assignedGroups KnowledgeAssignedGroup[]
  assignedUsers  KnowledgeAssignedUser[]
  categories     KnowledgeCategoriesOnKnowledge[]
  emailLogs      KnowledgeEmailLog[]
  tags           KnowledgeTagsOnKnowledge[]
  events         KnowledgeEventsOnKnowledge[]
  vectors        KnowledgeVector[]                @relation("KnowledgeVectors")

  @@index([slug])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([type])
  @@index([visibility])
  @@index([createdAt])
  @@map("KnowledgeArticles")
}

/// *
///  * KnowledgeCategoriesOnKnowledge - Junction table for many-to-many relationship
///  * Links Knowledge articles with Categories
model KnowledgeCategoriesOnKnowledge {
  knowledgeId String
  categoryId  String
  assignedAt  DateTime          @default(now())
  category    KnowledgeCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "KnowledgeCategoriesOnKnowledge_categoryId_fkey")
  knowledge   Knowledge         @relation(fields: [knowledgeId], references: [id], onDelete: Cascade, map: "KnowledgeCategoriesOnKnowledge_knowledgeId_fkey")

  @@id([knowledgeId, categoryId])
  @@index([categoryId], map: "KnowledgeCategoriesOnKnowledge_categoryId_idx")
  @@map("KnowledgeCategoriesOnKnowledge")
}

/// *
///  * KnowledgeTagsOnKnowledge - Junction table for many-to-many relationship
///  * Links Knowledge articles with Tags
model KnowledgeTagsOnKnowledge {
  knowledgeId String
  tagId       String
  assignedAt  DateTime     @default(now())
  knowledge   Knowledge    @relation(fields: [knowledgeId], references: [id], onDelete: Cascade, map: "KnowledgeTagsOnKnowledge_knowledgeId_fkey")
  tag         KnowledgeTag @relation(fields: [tagId], references: [id], onDelete: Cascade, map: "KnowledgeTagsOnKnowledge_tagId_fkey")

  @@id([knowledgeId, tagId])
  @@index([tagId], map: "KnowledgeTagsOnKnowledge_tagId_idx")
  @@map("KnowledgeTagsOnKnowledge")
}

/// *
///  * KnowledgeEventsOnKnowledge - Junction table for many-to-many relationship
///  * Links Knowledge articles with Events
model KnowledgeEventsOnKnowledge {
  knowledgeId String
  eventId     String
  assignedAt  DateTime  @default(now())
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  knowledge   Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)

  @@id([knowledgeId, eventId])
  @@index([eventId])
  @@map("KnowledgeEventsOnKnowledge")
}

/// *
///  * KnowledgeAssignedUser - Junction table for private article access
///  * Links Knowledge articles with Users who can access private articles
model KnowledgeAssignedUser {
  id          String    @id @default(cuid())
  knowledgeId String
  userId      String
  assignedAt  DateTime  @default(now())
  assignedBy  String?
  knowledge   Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade, map: "KnowledgeAssignedUsers_knowledgeId_fkey")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "KnowledgeAssignedUsers_userId_fkey")

  @@unique([knowledgeId, userId])
  @@index([userId], map: "KnowledgeAssignedUsers_userId_idx")
  @@map("KnowledgeAssignedUsers")
}

/// *
///  * KnowledgeAssignedGroup - Junction table for private article access via groups
///  * Links Knowledge articles with UserGroups who can access private articles
model KnowledgeAssignedGroup {
  id          String    @id @default(cuid())
  knowledgeId String
  groupId     String
  assignedAt  DateTime  @default(now())
  assignedBy  String?
  group       UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade, map: "KnowledgeAssignedGroup_groupId_fkey")
  knowledge   Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade, map: "KnowledgeAssignedGroup_knowledgeId_fkey")

  @@unique([knowledgeId, groupId], map: "KnowledgeAssignedGroup_knowledgeId_groupId_key")
  @@index([groupId], map: "KnowledgeAssignedGroup_groupId_idx")
  @@map("KnowledgeAssignedGroups")
}

/// *
///  * KnowledgeModuleType - Module types for Knowledge in Profile Builder
///  * Defines fields that can be displayed in user profile modules
///  * System: "knowledge" with keys like "knowledge_article_preview", "knowledge_featured", etc.
model KnowledgeModuleType {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  system      String   @default("knowledge")
  description String?
  icon        String?
  fieldSchema Json?
  isEnabled   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([system])
  @@index([key])
  @@map("KnowledgeModuleTypes")
}

/// *
///  * KnowledgeEmailLog - Tracks emails sent when articles are assigned to users/groups
///  * Prevents duplicate emails and maintains history of notifications
model KnowledgeEmailLog {
  id              String    @id @default(cuid())
  knowledgeId     String
  recipientId     String
  subject         String
  recipient_email String
  type            String
  sentAt          DateTime
  status          String
  errorMessage    String?
  triggeredBy     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  knowledge       Knowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  recipient       User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([knowledgeId, recipientId, sentAt])
  @@index([knowledgeId])
  @@index([recipientId])
  @@index([status])
  @@index([sentAt])
  @@map("KnowledgeEmailLogs")
}

/// *
///  * PostCategory - Categories for post articles
///  * Gốc cho việc phân loại các bài viết post
model PostCategory {
  id          String                 @id @default(cuid())
  name        String
  slug        String
  description String?
  type        String                 @default("blog")
  color       String?                @default("#000000")
  icon        String?
  order       Int                    @default(0)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  posts       PostCategoriesOnPost[]

  @@unique([name, type])
  @@unique([slug, type])
  @@index([slug])
  @@index([order])
  @@index([type])
  @@map("PostCategories")
}

/// *
///  * PostTag - Tags for post articles (flexible tagging system)
///  * Tags giúp người dùng tìm kiếm và filter bài viết
model PostTag {
  id        String           @id @default(cuid())
  name      String
  slug      String
  type      String           @default("blog")
  color     String?          @default("#666666")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  posts     PostTagsOnPost[]

  @@unique([name, type])
  @@unique([slug, type])
  @@index([slug])
  @@index([type])
  @@map("PostTags")
}

/// *
///  * Post - Main post article model
///  * Lưu trữ các bài viết blog với đầy đủ metadata
model Post {
  id          String                 @id @default(cuid())
  title       String
  slug        String                 @unique
  content     String                 @db.Text
  excerpt     String?                @db.Text
  thumbnail   String?                @db.Text
  type        String                 @default("blog")
  visibility  String                 @default("public")
  viewCount   Int                    @default(0)
  isPublished Boolean                @default(false)
  publishedAt DateTime?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  categories  PostCategoriesOnPost[]
  tags        PostTagsOnPost[]
  speakerEvents EventSpeakersOnPosts[]
  sponsorEvents EventSponsorsOnPosts[]
  metaData    Json

  @@index([slug])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([type])
  @@index([visibility])
  @@index([createdAt])
  @@map("Posts")
}

/// *
///  * PostCategoriesOnPost - Junction table for many-to-many relationship
///  * Links Post articles with Categories
model PostCategoriesOnPost {
  postId     String
  categoryId String
  assignedAt DateTime     @default(now())
  category   PostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "PostCategoriesOnPost_categoryId_fkey")
  post       Post         @relation(fields: [postId], references: [id], onDelete: Cascade, map: "PostCategoriesOnPost_postId_fkey")

  @@id([postId, categoryId])
  @@index([categoryId], map: "PostCategoriesOnPost_categoryId_idx")
  @@map("PostCategoriesOnPost")
}

/// *
///  * PostTagsOnPost - Junction table for many-to-many relationship
///  * Links Post articles with Tags
model PostTagsOnPost {
  postId     String
  tagId      String
  assignedAt DateTime @default(now())
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade, map: "PostTagsOnPost_postId_fkey")
  tag        PostTag  @relation(fields: [tagId], references: [id], onDelete: Cascade, map: "PostTagsOnPost_tagId_fkey")

  @@id([postId, tagId])
  @@index([tagId], map: "PostTagsOnPost_tagId_idx")
  @@map("PostTagsOnPost")
}

/// *
///  * EventSpeakersOnPosts - Junction table for many-to-many relationship
///  * Links Event articles with Speaker Posts
model EventSpeakersOnPosts {
  eventId    String
  postId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "EventSpeakersOnPosts_eventId_fkey")
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade, map: "EventSpeakersOnPosts_postId_fkey")

  @@id([eventId, postId])
  @@index([eventId], map: "EventSpeakersOnPosts_eventId_idx")
  @@index([postId], map: "EventSpeakersOnPosts_postId_idx")
  @@map("EventSpeakersOnPosts")
}

/// *
///  * EventSponsorsOnPosts - Junction table for many-to-many relationship
///  * Links Event articles with Sponsor Posts
model EventSponsorsOnPosts {
  eventId    String
  postId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, map: "EventSponsorsOnPosts_eventId_fkey")
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade, map: "EventSponsorsOnPosts_postId_fkey")

  @@id([eventId, postId])
  @@index([eventId], map: "EventSponsorsOnPosts_eventId_idx")
  @@index([postId], map: "EventSponsorsOnPosts_postId_idx")
  @@map("EventSponsorsOnPosts")
}

model BackupRecord {
  id            String          @id @default(cuid())
  fileName      String          @db.VarChar(255)
  fileSize      BigInt          @default(0)
  status        BackupStatus   @default(PENDING)
  createdAt     DateTime     @default(now())
  completedAt   DateTime?
  errorMessage  String?      @db.Text
  uploadedBy    String
  r2Url         String?      @db.VarChar(500)
  backupType    BackupType   @default(MANUAL)
  retentionDays Int          @default(30)

  @@index([backupType])
  @@index([createdAt])
  @@index([status])
  @@map("BackupRecords")
}

model BackupStats {
  id                String    @id @default(cuid())
  totalBackups      Int       @default(0)
  successfulBackups Int       @default(0)
  failedBackups     Int       @default(0)
  totalSize         BigInt    @default(0)
  lastBackupDate    DateTime?
  updatedAt         DateTime  @default(now()) @updatedAt

  @@map("BackupStats")
}

model BackupSettings {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(255)
  value       String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@index([key])
  @@map("BackupSettings")
}

/// *
///  * Event - Main event model for ticketing and attendee management
///  * Supports internal/external/hybrid ticketing modes
///  * Two types: with_sessions (agenda) or landing_only (no public content)
model Event {
  id                     String                       @id @default(cuid())
  title                  String
  slug                   String                       @unique
  description            String                       @db.Text
  startDate              DateTime
  endDate                DateTime
  location               String?
  capacity               Int?
  status                 EventStatus                @default(DRAFT)
  eventType              EventType                    @default(WITH_SESSIONS)
  ticketingMode          TicketingMode                @default(INTERNAL)
  externalTicketUrl      String?
  externalTicketProvider String?
  thumbnailId            String?
  enableCheckIn          Boolean                      @default(true)
  metaData               Json?
  createdById            String
  updatedById            String
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  createdBy              User                         @relation("EventCreatedBy", fields: [createdById], references: [id])
  updatedBy              User                         @relation("EventUpdatedBy", fields: [updatedById], references: [id])
  thumbnail              Media?                       @relation(fields: [thumbnailId], references: [id])
  sessions               EventSession[]
  ticketTypes            TicketType[]
  registrations          Registration[]
  knowledge              KnowledgeEventsOnKnowledge[]
  microsite              EventMicrosite?
  sponsorMaterials       SponsorMaterial[]
  speakerPosts           EventSpeakersOnPosts[]
  sponsorPosts           EventSponsorsOnPosts[]

  @@index([slug])
  @@index([status])
  @@index([eventType])
  @@index([ticketingMode])
  @@index([startDate])
  @@index([createdAt])
}

/// *
///  * EventSession - Sessions within an event (only for eventType: WITH_SESSIONS)
///  * Represents individual sessions like workshops, talks, etc.
model EventSession {
  id          String   @id @default(cuid())
  eventId     String
  title       String
  description String?  @db.Text
  startTime   DateTime
  endTime     DateTime
  speaker     String?
  capacity    Int?
  room        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([startTime])
}

/// *
///  * TicketType - Types of tickets available for an event (internal/hybrid only)
///  * Defines pricing, quantity, and sale periods
model TicketType {
  id          String    @id @default(cuid())
  eventId     String
  name        String
  description String?
  price       Float
  quantity    Int
  maxPerUser  Int       @default(1)
  saleStart   DateTime?
  saleEnd     DateTime?
  isActive    Boolean   @default(true)
  isExternal  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets     Ticket[]

  @@index([eventId])
  @@index([isActive])
}

/// *
///  * Payment - Tracks user payment history for events
///  * Stores payment details for auditing and refunds
model Payment {
  id            String             @id @default(cuid())
  userId        String
  amount        Float
  currency      String             @default("USD")
  status        PaymentStatus  @default(PENDING)
  paymentMethod String?
  paymentId     String? // External provider ID
  description   String?
  metadata      Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tickets       Ticket[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

/// *
///  * Ticket - Individual tickets purchased (internal/hybrid only)
///  * Links to payment and user, with QR for check-in
model Ticket {
  id             String        @id @default(cuid())
  ticketTypeId   String
  userId         String
  qrCode         String        @unique
  status         TicketStatus  @default(SOLD)
  purchasedAt    DateTime      @default(now())
  usedAt         DateTime?
  paymentId      String?
  registrationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  ticketType     TicketType    @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payment        Payment?      @relation(fields: [paymentId], references: [id])
  registration   Registration? @relation(fields: [registrationId], references: [id])

  @@index([ticketTypeId])
  @@index([userId])
  @@index([qrCode])
  @@index([status])
}

/// *
///  * Registration - Core registration for all event modes
///  * Tracks attendees, status, and custom data
model Registration {
  id               String          @id @default(cuid())
  eventId          String
  userId           String?
  status           RegistrationStatus   @default(PENDING)
  ticketSource     TicketSource       @default(INTERNAL)
  externalTicketId String?
  customData       Json?
  registeredAt     DateTime           @default(now())
  checkedInAt      DateTime?
  checkedInById    String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  event            Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User?              @relation(fields: [userId], references: [id])
  checkedInBy      User?              @relation("RegistrationCheckedInBy", fields: [checkedInById], references: [id])
  checkIns         CheckIn[]
  tickets          Ticket[]

  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([registeredAt])
}

/// *
///  * CheckIn - Records for check-in events
///  * Optional based on enableCheckIn flag
model CheckIn {
  id             String       @id @default(cuid())
  registrationId String
  checkedInAt    DateTime     @default(now())
  checkedInById  String
  location       String?
  deviceInfo     Json?
  createdAt      DateTime     @default(now())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  checkedInBy    User         @relation(fields: [checkedInById], references: [id])

  @@index([registrationId])
  @@index([checkedInAt])
}

model Contact {
  id         String   @id @default(cuid())
  customerId String // Liên kết với Customer hiện có
  firstName  String
  lastName   String
  email      String   @unique
  phone      String?
  title      String?
  isPrimary  Boolean  @default(false)
  tags       String? // JSON array of tags
  metaData   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?

  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  testOrders TestOrder[] // Test orders where this contact is the primary contact
  trainingEngagements TrainingEngagement[] // Training engagements where this contact is the primary contact
  trainingRegistrations TrainingRegistration[] // Training registrations for this contact
  
  @@index([customerId])
  @@index([email])
}

model Opportunity {
  id            String           @id @default(cuid())
  customerId    String // Liên kết với Customer hiện có
  title         String
  description   String?
  value         Float?
  stage         OpportunityStage @default(PROSPECTING)
  probability   Int?             @default(0)
  expectedClose DateTime?
  ownerId       String
  source        String?
  metaData      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdBy     String?
  updatedBy     String?

  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  owner       User         @relation("OpportunityOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  engagements Engagement[]

  @@index([customerId])
  @@index([stage])
  @@index([ownerId])
}

model Engagement {
  id            String          @id @default(cuid())
  opportunityId String?
  customerId    String // Liên kết với Customer hiện có
  title         String
  type          EngagementType // DESIGN, TESTING, TRAINING, EVENT
  status        EngagementStatus   @default(DRAFT)
  priority      String?          @default("MEDIUM")
  startDate     DateTime?
  dueDate       DateTime?
  completedAt   DateTime?
  budget        Float?
  description   String?
  assignedTo    String? // User ID
  metaData      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdBy     String?
  updatedBy     String?

  opportunity    Opportunity?    @relation(fields: [opportunityId], references: [id])
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  testOrders     TestOrder[] // For testing engagements
  designProjects DesignProject[] // For design engagements
  trainingEngagements TrainingEngagement[] // For training engagements

  @@index([customerId])
  @@index([type])
  @@index([status])
  @@index([assignedTo])
}

model Interaction {
  id           String          @id @default(cuid())
  customerId   String? // Liên kết với Customer hiện có
  contactId    String?
  testOrderId  String? // Liên kết với TestOrder để log testing discussions
  type         InteractionType // MEETING, CALL, EMAIL, NOTE
  subject      String
  description  String?
  date         DateTime
  duration     Int? // minutes
  participants String? // JSON array
  outcome      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  createdBy    String?
  updatedBy    String?

  testOrder TestOrder? @relation(fields: [testOrderId], references: [id])

  @@index([customerId])
  @@index([contactId])
  @@index([testOrderId])
  @@index([type])
  @@index([date])
}

model Task {
  id          String  @id @default(cuid())
  title       String
  description String?

  // Generic entity linking
  entityType String // ENGAGEMENT, TEST_ORDER, TRAINING_SESSION, SUPPORT_TICKET, etc.
  entityId   String // ID của entity tương ứng

  status      TaskStatus @default(TODO)
  priority    String     @default("MEDIUM")
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?

  // Task-specific fields
  taskType String? // TESTING_SAMPLE, TRAINING_MODULE, SUPPORT_ISSUE, etc.
  category String? // For filtering/grouping
  tags     String? // JSON array

  // Workflow fields
  parentTaskId String? // For subtasks
  order        Int     @default(0) // For kanban ordering

  metaData  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  // Relations
  parentTask Task?  @relation("TaskHierarchy", fields: [parentTaskId], references: [id])
  subtasks   Task[] @relation("TaskHierarchy")

  @@index([entityType, entityId])
  @@index([status])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([taskType])
  @@index([category])
}

model TestOrder {
  id           String          @id @default(cuid())
  engagementId String
  title        String
  description  String?
  status       TestOrderStatus   @default(DRAFT)
  priority     String          @default("MEDIUM")
  requestedBy  String // User ID
  assignedTo   String? // User ID
  contactId    String? // Contact ID - Primary contact for this test order
  startDate    DateTime?
  dueDate      DateTime?
  completedAt  DateTime?
  budget       Float?
  notes        String?
  metaData     Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  createdBy    String?
  updatedBy    String?

  engagement   Engagement         @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  contact      Contact?           @relation(fields: [contactId], references: [id])
  samples      Sample[]
  testSuites   TestSuiteOnOrder[]
  tests        Test[]
  reports      TestReport[]
  interactions Interaction[] // Related interactions/discussions

  @@index([engagementId])
  @@index([status])
  @@index([assignedTo])
  @@index([contactId])
  @@index([dueDate])
}

model Sample {
  id              String       @id @default(cuid())
  testOrderId     String
  name            String
  description     String?
  type            SampleType   @default(PHYSICAL)
  quantity        Int          @default(1)
  receivedDate    DateTime?
  receivedFrom    String?
  storageLocation String?
  condition       String?
  status          SampleStatus @default(RECEIVED)
  notes           String?
  mediaIds        String? // JSON array of Media IDs
  metaData        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       String?
  updatedBy       String?

  testOrder TestOrder @relation(fields: [testOrderId], references: [id], onDelete: Cascade)
  tests     Test[]

  @@index([testOrderId])
  @@index([status])
}

model TestSuite {
  id             String   @id @default(cuid())
  name           String
  description    String?
  category       String?
  isActive       Boolean  @default(true)
  estimatedHours Float?
  metaData       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?
  updatedBy      String?

  orders TestSuiteOnOrder[]
  tests  Test[]

  @@index([category])
  @@index([isActive])
}

model TestSuiteOnOrder {
  id          String   @id @default(cuid())
  testOrderId String
  testSuiteId String
  assignedAt  DateTime @default(now())
  assignedBy  String?

  testOrder TestOrder @relation(fields: [testOrderId], references: [id], onDelete: Cascade)
  testSuite TestSuite @relation(fields: [testSuiteId], references: [id], onDelete: Cascade)

  @@unique([testOrderId, testSuiteId])
  @@index([testOrderId])
  @@index([testSuiteId])
}

model Test {
  id             String     @id @default(cuid())
  testOrderId    String?
  testSuiteId    String?
  sampleId       String?
  name           String
  description    String?
  method         String?
  parameters     Json? // Test parameters
  expectedResult String?
  actualResult   String?
  status         TestStatus @default(PENDING)
  startedAt      DateTime?
  completedAt    DateTime?
  performedBy    String? // User ID
  notes          String?
  data           Json? // Captured test data
  mediaIds       String? // JSON array of Media IDs
  metaData       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  createdBy      String?
  updatedBy      String?

  testOrder TestOrder? @relation(fields: [testOrderId], references: [id], onDelete: Cascade)
  testSuite TestSuite? @relation(fields: [testSuiteId], references: [id])
  sample    Sample?    @relation(fields: [sampleId], references: [id])

  @@index([testOrderId])
  @@index([status])
  @@index([performedBy])
}

model TestReport {
  id              String       @id @default(cuid())
  testOrderId     String
  title           String
  summary         String?
  findings        String?        @db.Text
  recommendations String?        @db.Text
  status          ReportStatus  @default(DRAFT)
  version         Int          @default(1)
  generatedAt     DateTime?
  approvedAt      DateTime?
  approvedBy      String?
  publishedAt     DateTime?
  mediaId         String? // PDF report file
  metaData        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       String?
  updatedBy       String?

  testOrder TestOrder @relation(fields: [testOrderId], references: [id], onDelete: Cascade)

  @@index([testOrderId])
  @@index([status])
  @@index([publishedAt])
}

// ============================================================================
// DESIGN x DEVELOPMENT MODELS
// ============================================================================

/// *
/// DesignProject - Main container for design engagement
/// Linked to Engagement (type: DESIGN)
/// Similar to TestOrder in Testing vertical
model DesignProject {
  id           String              @id @default(cuid())
  engagementId String
  customerId   String
  title        String
  description  String?
  status       DesignProjectStatus @default(DRAFT)
  priority     String              @default("MEDIUM")
  requestedBy  String
  assignedTo   String?
  startDate    DateTime?
  dueDate      DateTime?
  completedAt  DateTime?
  budget       Float?
  metaData     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  createdBy    String?
  updatedBy    String?

  engagement Engagement      @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  customer   Customer        @relation("DesignProjects", fields: [customerId], references: [id], onDelete: Cascade)
  brief      DesignBrief?
  designs    ProductDesign[]
  deck       DesignDeck?
  reviews    DesignReview[]

  @@index([engagementId])
  @@index([customerId])
  @@index([status])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([createdAt])
}

/// *
/// DesignBrief - Intake form and requirements
/// One brief per project, captures all initial requirements
model DesignBrief {
  id              String            @id @default(cuid())
  designProjectId String            @unique
  brandAssets     String?
  targetAudience  String?
  constraints     String?
  inspirations    String?
  deliverables    String?
  budget          Float?
  timeline        String?
  notes           String?            @db.Text
  mediaIds        String?
  status          DesignBriefStatus     @default(DRAFT)
  approvedAt      DateTime?
  approvedBy      String?
  metaData        Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  createdBy       String?
  updatedBy       String?

  designProject DesignProject @relation(fields: [designProjectId], references: [id], onDelete: Cascade)

  @@index([designProjectId])
  @@index([status])
  @@index([createdAt])
}

/// *
/// ProductDesign - Individual design for a product
/// Can have multiple versions/iterations
/// Links to single TechPack when approved
model ProductDesign {
  id                 String              @id @default(cuid())
  designProjectId    String
  name               String
  description        String?
  designType         String          @default("GRAPHIC")
  productType        String?
  mockupUrl          String?
  graphicSpecsFile   String?
  layerInfo          Json?
  colorSeparations   String?
  status             ProductDesignStatus   @default(DRAFT)
  feasibilityNotes   String?             @db.Text
  compatibilityCheck Boolean             @default(false)
  decorationDetails  Json?
  mediaIds           String?
  version            Int                 @default(1)
  parentDesignId     String?
  assignedTo         String?
  startedAt          DateTime?
  completedAt        DateTime?
  metaData           Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdBy          String?
  updatedBy          String?

  designProject DesignProject   @relation(fields: [designProjectId], references: [id], onDelete: Cascade)
  parentDesign  ProductDesign?  @relation("DesignVersions", fields: [parentDesignId], references: [id])
  versions      ProductDesign[] @relation("DesignVersions")
  techPack      TechPack?
  reviews       DesignReview[]

  @@index([designProjectId])
  @@index([status])
  @@index([designType])
  @@index([productType])
  @@index([assignedTo])
  @@index([parentDesignId])
  @@index([createdAt])
}

/// *
/// TechPack - Manufacturing specifications and output files
/// Created from approved ProductDesign
/// Contains sizing, materials, production specs, output files
model TechPack {
  id               String         @id @default(cuid())
  productDesignId  String         @unique
  name             String
  description      String?
  sizing           Json?
  materials        Json?
  colors           Json?
  decorationMethod String
  productionNotes  String?        @db.Text
  qualitySpecs     Json?
  outputFiles      String?        @db.Text
  status           TechPackStatus  @default(DRAFT)
  approvedAt       DateTime?
  approvedBy       String?
  metaData         Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  createdBy        String?
  updatedBy        String?

  productDesign ProductDesign @relation(fields: [productDesignId], references: [id], onDelete: Cascade)

  @@index([productDesignId])
  @@index([status])
  @@index([decorationMethod])
  @@index([approvedAt])
  @@index([createdAt])
}

/// *
/// DesignDeck - Collection and presentation of approved designs
/// One main deck per project
/// Contains references to selected designs and documentation
model DesignDeck {
  id              String           @id @default(cuid())
  designProjectId String           @unique
  title           String
  description     String?
  coverUrl        String?
  designIds       String?
  deckUrl         String?
  mediaIds        String?
  status          DesignDeckStatus @default(DRAFT)
  publishedAt     DateTime?
  publishedBy     String?
  version         Int              @default(1)
  notes           String?
  metaData        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdBy       String?
  updatedBy       String?

  designProject DesignProject @relation(fields: [designProjectId], references: [id], onDelete: Cascade)

  @@index([designProjectId])
  @@index([status])
  @@index([publishedAt])
  @@index([createdAt])
}


/// *
///  * Training x Support Models
model TrainingEngagement {
  id                 String                 @id @default(cuid())
  engagementId       String                 @unique
  customerId         String
  title              String
  description        String?                @db.Text
  trainingType       TrainingType           @default(INSTRUCTOR_LED)
  deliveryMethod     DeliveryMethod         @default(HYBRID)
  startDate          DateTime?
  endDate            DateTime?
  totalDurationHours Float?
  targetAudience     String?
  maxParticipants    Int?
  minParticipants    Int?
  status             TrainingStatus          @default(DRAFT)
  phase              TrainingPhase          @default(DISCOVERY)
  certificationLevel CertificationLevel     @default(NONE)
  requestedBy        String
  requestedByUserId  String?
  instructorId       String?
  coordinatorId      String?
  contactId          String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  startedAt          DateTime?
  completedAt        DateTime?
  createdBy          String?
  updatedBy          String?
  metaData           Json?
  
  engagement         Engagement             @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  customer           Customer               @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contact            Contact?               @relation(fields: [contactId], references: [id])
  instructor         User?                  @relation("TrainingEngagementInstructor", fields: [instructorId], references: [id])
  coordinator        User?                  @relation("TrainingEngagementCoordinator", fields: [coordinatorId], references: [id])
  requestedByUser    User?                  @relation("TrainingEngagementRequestedBy", fields: [requestedByUserId], references: [id])
  sessions           TrainingSession[]
  assessments        Assessment[]
  implementationPlan ImplementationPlan?
  reports             TrainingReport[]
  registrations      TrainingRegistration[]
  
  @@index([engagementId])
  @@index([customerId])
  @@index([status])
  @@index([phase])
  @@index([instructorId])
  @@index([startDate])
  @@index([completedAt])
}

/// *
///  * TrainingRegistration - Core registration for training engagements
///  * Tracks attendees, status, and custom data
model TrainingRegistration {
  id                    String          @id @default(cuid())
  trainingEngagementId  String
  userId                String?
  contactId             String?
  status                RegistrationStatus   @default(PENDING)
  registrationSource    TicketSource          @default(INTERNAL)
  externalRegistrationId String?
  customData            Json?
  registeredAt          DateTime              @default(now())
  checkedInAt           DateTime?
  checkedInById         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  trainingEngagement    TrainingEngagement    @relation(fields: [trainingEngagementId], references: [id], onDelete: Cascade)
  user                  User?                 @relation(fields: [userId], references: [id])
  contact               Contact?              @relation(fields: [contactId], references: [id])
  checkedInBy           User?                 @relation("TrainingRegistrationCheckedInBy", fields: [checkedInById], references: [id])
  checkIns              TrainingCheckIn[]

  @@index([trainingEngagementId])
  @@index([userId])
  @@index([contactId])
  @@index([status])
  @@index([registeredAt])
  @@unique([trainingEngagementId, userId])
  @@unique([trainingEngagementId, contactId])
}

/// *
///  * TrainingCheckIn - Records for training check-in events
///  * Optional based on enableCheckIn flag
model TrainingCheckIn {
  id                    String                @id @default(cuid())
  trainingRegistrationId String
  trainingSessionId     String?
  checkedInAt           DateTime              @default(now())
  checkedInById         String
  location              String?
  deviceInfo            Json?
  createdAt             DateTime              @default(now())
  trainingRegistration  TrainingRegistration  @relation(fields: [trainingRegistrationId], references: [id], onDelete: Cascade)
