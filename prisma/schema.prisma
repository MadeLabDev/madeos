  updatedAt   DateTime       @updatedAt

  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  file        Media?         @relation(fields: [fileId], references: [id])
  createdBy   User           @relation("SponsorMaterialCreatedBy", fields: [createdById], references: [id])
  updatedBy   User           @relation("SponsorMaterialUpdatedBy", fields: [updatedById], references: [id])
  approvedBy  User?          @relation("SponsorMaterialApprovedBy", fields: [approvedById], references: [id])

  @@index([eventId])
  @@index([sponsorId])
  @@index([status])
  @@index([dueDate])
}

/// *
///  * KnowledgeVector - Vector embeddings for semantic search (RAG Foundation)
///  * Stores embeddings of Knowledge article chunks for vector similarity search
///  * Feature-flagged: Only used when RAG is enabled via Settings.rag_enabled
///  * Non-breaking: Dormant until activation, supports future AI features
model KnowledgeVector {
  id              String    @id @default(cuid())
  
  // Legacy Knowledge support (for backward compatibility with existing data)
  knowledgeId     String?
  knowledge       Knowledge? @relation("KnowledgeVectors", fields: [knowledgeId], references: [id], onDelete: Cascade)

  // Cross-feature support: which module/entity this vector belongs to
  sourceModule    String    // Module name: "knowledge", "contacts", "opportunities", "events", "interactions", etc.
  sourceId        String    // Entity ID (articleId, contactId, opportunityId, etc.)
  sourceType      String    @default("text") // Type: "text", "summary", "description", "comment", etc.

  content         String    @db.Text              // Original text chunk
  embedding       String?   @db.Text              // JSON array of floats: "[-0.123, 0.456, ...]" (384 dims for MiniLM-L6-v2, 1536 for GPT)
  embeddingModel  String    @default("minimlm-l6-v2") // Track which model generated this
  chunkIndex      Int       @default(0)           // Order for multi-chunk documents
  tokenCount      Int       @default(0)           // For usage tracking
  hash            String?                         // Dedup same content chunks (nullable, non-unique to allow multi-source)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([knowledgeId])
  @@index([sourceModule])
  @@index([sourceId])
  @@index([sourceModule, sourceId])
  @@index([embeddingModel])
  @@index([createdAt])
  @@index([hash])
}

/// *
///  * VectorSearchLog - Audit trail for vector searches (analytics, debugging)
///  * Tracks RAG queries for performance monitoring and improvement
///  * Used for search analytics when RAG enabled
model VectorSearchLog {
  id                  String    @id @default(cuid())
  query               String    @db.Text
  topK                Int       @default(3)
  minSimilarity       Float     @default(0.6)
  resultKnowledgeIds  String?   @db.Text            // JSON array of matched knowledge IDs
  similarityScores    String?   @db.Text            // JSON array of similarity scores
  responseTimeMs      Int       @default(0)
  modelUsed           String    @default("minimlm-l6-v2")
  status              String    @default("success") // success, error, no_results

  userId              String?
  user                User?     @relation("VectorSearchLogs", fields: [userId], references: [id], onDelete: SetNull)
  createdAt           DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([modelUsed])
}

/// *
///  * EmbeddingCache - Cache pre-computed embeddings to reduce API costs
///  * Stores embeddings by hash to avoid re-computing same content
///  * Significant cost savings for frequently used content
model EmbeddingCache {
  id              String    @id @default(cuid())
  contentHash     String    @unique              // SHA256 of content
  content         String    @db.Text            // Original content
  embedding       String    @db.Text            // JSON array of embedding floats
  embeddingModel  String                        // e.g. "text-embedding-3-large"
  dimensions      Int                           // e.g. 3072 for large model
  tokenCount      Int                           // Tokens used for cost tracking
  costUSD         Float     @default(0)         // Cost of creating this embedding
  
  hitCount        Int       @default(0)         // How many times reused
  lastUsedAt      DateTime?
  createdAt       DateTime  @default(now())
  
  @@unique([contentHash, embeddingModel])
  @@index([embeddingModel])
  @@index([createdAt])
}

/// *
///  * RAGSession - Track RAG query sessions for context & conversation
///  * Enables multi-turn conversations with memory
///  * Tracks conversation history and costs
model RAGSession {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation("RAGSessions", fields: [userId], references: [id], onDelete: Cascade)
  
  title           String?
  messageCount    Int       @default(0)
  totalCostUSD    Float     @default(0)
  totalTokens     Int       @default(0)
  
  status          String    @default("active")
  lastMessageAt   DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  messages        RAGMessage[]
  
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

/// *
///  * RAGMessage - Individual messages in RAG conversations
///  * Tracks queries, answers, sources, and performance metrics
model RAGMessage {
  id              String    @id @default(cuid())
  sessionId       String
  session         RAGSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  role            String
  query           String    @db.Text
  answer          String?   @db.Text
  
  sourceIds       String?   @db.Text
  similarityScores String? @db.Text
  
  embeddingModel  String?
  llmModel        String?
  
  tokensUsed      Int       @default(0)
  costUSD         Float     @default(0)
  responseTimeMs  Int       @default(0)
  
  metadata        Json?
  
  createdAt       DateTime  @default(now())
  
  @@index([sessionId])
  @@index([role])
  @@index([createdAt])
}

/// *
///  * RAGFeedback - User feedback on RAG answers for quality improvement
///  * Tracks accuracy, relevance, usefulness for model retraining
model RAGFeedback {
  id              String    @id @default(cuid())
  messageId       String    @unique
  userId          String
  user            User      @relation("RAGFeedback", fields: [userId], references: [id], onDelete: Cascade)
  
  rating          Int?
  isHelpful       Boolean?
  isAccurate      Boolean?
  
  comments        String?   @db.Text
  suggestedAnswer String?   @db.Text
  
  createdAt       DateTime  @default(now())
  
  @@index([userId])
  @@index([createdAt])
  @@index([isHelpful])
}

/// *
///  * RAGMetrics - Aggregate metrics for monitoring RAG performance
///  * Daily snapshot of system health, costs, and usage
model RAGMetrics {
  id              String    @id @default(cuid())
  date            DateTime  @unique
  
  totalQueries    Int       @default(0)
  totalAnswers    Int       @default(0)
  averageLatencyMs Int      @default(0)
  totalTokensUsed Int       @default(0)
  totalCostUSD    Float     @default(0)
  
  avgAccuracy     Float?
  avgHelpfulness  Float?
  feedbackCount   Int       @default(0)
  
  embeddingModel  String?
  llmModel        String?
  
  metadata        Json?
  
  createdAt       DateTime  @default(now())
  
  @@index([date])
}

