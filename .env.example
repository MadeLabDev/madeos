# Environment variables example
# Copy this file to .env.local and fill in your values

# Development Mode (set to "true" to enable dev features)
NEXT_PUBLIC_DEV_MODE="true"

# Database
DATABASE_URL="mysql://user:password@localhost:3306/database_name"
# Database Search Mode - Enable case-insensitive search (true for PostgreSQL/MySQL, false for SQLite)
DATABASE_CASE_INSENSITIVE="false"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-min-32-characters-change-this"
AUTH_SECRET="your-super-secret-key-min-32-characters-change-this"

# Anti Spam
TURNSTILE_API_KEY=""

# Two-Factor Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-encryption-key-for-2fa-secrets"
NEXT_PUBLIC_APP_NAME="MADE App"
NEXT_PUBLIC_APP_ISSUER="madelab.io"

# Email Configuration (for password reset, notifications)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SECURE="false"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-password"
EMAIL_FROM="your-email@gmail.com"
# Brove API - Send Email for form 
BREVO_API=
BREVO_SMTP=
BREVO_SMTP_KEY=
BREVO_PORT=587
BREVO_LOGIN=
ADMIN_EMAIL=

# Payment Providers
# Provide the credentials for the provider you select in the Payment settings tab
STRIPE_API_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
SQUARE_ACCESS_TOKEN=""
SQUARE_LOCATION_ID=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# Pusher (for real-time updates)
PUSHER_APP_ID="your-pusher-app-id"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# S3/R2 Storage (for file uploads)
R2_BUCKET_DEV="bucket-name-dev"
R2_BUCKET_PROD="bucket-name-prod"
R2_BUCKET_PUBLIC="https://your-bucket-url.r2.dev"
R2_ACCOUNT_ID="your-account-id"
S3_COMPATIBLE_ACCESS_ID="your-access-key"
S3_COMPATIBLE_SECRET_KEY="your-secret-key"
# R2 Backup Configuration
R2_ENDPOINT=https://your-bucket-url.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
# Backup Settings
BACKUP_RETENTION_DAYS="30"  # Keep backups for 30 days
BACKUP_SCHEDULE_HOUR="2"    # Run daily backup at 2:00 AM

# App Configuration
NEXT_PUBLIC_APP_NAME="MADE App"
NEXT_PUBLIC_APP_ISSUER="madelab.io"

# Google OAuth (Optional - if you want to enable Google Sign In)
# Get credentials from: https://console.cloud.google.com/
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cache Settings
# Enable/disable caching for Users/Profile and Settings modules
# Default: false (caching disabled, original behavior preserved)
# Set to true to cache database queries (1-hour revalidation)
# See docs/CACHING_STRATEGY.md for implementation details
NEXT_PUBLIC_ENABLE_CACHE=false

# ============================================================================
# RAG & AI Configuration (Foundation - Optional, Free for Localhost)
# All below are OPTIONAL. RAG features are disabled by default.
# Enable via Settings panel (rag_enabled = true) when ready to activate.
# ============================================================================

# LOCAL DEVELOPMENT STRATEGY (DEFAULT - FREE):
# - EMBEDDING_PROVIDER="local" uses free local embeddings (all-MiniLM-L6-v2, 384 dims)
# - LLM_PROVIDER="none" runs in search-only mode (no LLM API calls)
# - No API keys needed for localhost development
# - Zero cost for development and testing

# Embedding Model Configuration - LOCAL (FREE) FOR LOCALHOST
# Using free local embeddings for development
# Switch to paid providers (openai, gemini, cohere) only when needed in production
EMBEDDING_PROVIDER="local"
EMBEDDING_MODEL="all-MiniLM-L6-v2"  # Free local model, no API key needed

# LLM Provider Configuration - NONE (SEARCH ONLY) FOR LOCALHOST
# Using search-only mode by default (no LLM calls)
# Switch to paid providers (groq, openai) only when needed in production
LLM_PROVIDER="none"

# Premium AI API Keys - ONLY CONFIGURE WHEN NEEDED FOR PRODUCTION
# Leave empty for localhost development to use free local models

# OpenAI API Key (required only if switching to OpenAI in production)
# Get key from: https://platform.openai.com/api-keys
# Models: text-embedding-3-large (3072 dims, $0.13/1M tokens), GPT-4 Turbo
OPENAI_API_KEY=""

# Groq API Key (required only if switching to Groq LLM in production)
# Get key from: https://console.groq.com/keys (recommended free LLM option)
# Fast inference, no cost during testing period
GROQ_API_KEY=""

# Google Gemini API Key (required only if switching to Gemini in production)
# Get key from: https://makersuite.google.com/app/apikey
# Models: embedding-001 (1408 dims), Gemini Pro
GOOGLE_GEMINI_API_KEY=""

# Cohere API Key (required only if switching to Cohere in production)
# Get key from: https://dashboard.cohere.ai/api-keys
# Model: embed-english-v3.0 (1024 dims)
COHERE_API_KEY=""

# Additional LLM Settings (used only when LLM_PROVIDER is set to paid provider)
# Temperature: 0 (deterministic) to 2 (creative)
# For RAG: recommended 0.3 (consistency for facts)
RAG_LLM_TEMPERATURE="0.3"

# Max tokens for LLM responses (1024-4096)
RAG_LLM_MAX_TOKENS="2048"

# Embedding Cache Settings
# Enable cache to reduce embedding API costs by 60-80%
RAG_EMBEDDING_CACHE_ENABLED="true"

# Maximum embeddings to batch process at once (1-100)
RAG_EMBEDDING_BATCH_SIZE="100"

# RAG Feature Settings
# Cost threshold per month (optional - triggers alerts)
RAG_COST_THRESHOLD_USD="100"

# Enable feedback collection for quality improvement
RAG_FEEDBACK_ENABLED="true"

# Enable detailed metrics tracking
RAG_METRICS_ENABLED="true"

# Ollama Configuration (optional - for local LLM deployment)
# Install Ollama: https://ollama.ai
# Run: ollama pull mistral
OLLAMA_API_URL="http://localhost:11434"


