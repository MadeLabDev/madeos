  Menu --> Contact["👥 CONTACTS<br/>━━━━━━━<br/>Person Management<br/>Title, Department<br/>Email, Phone<br/>Role Tags"]
  
  Menu --> Opportunity["🎯 OPPORTUNITIES<br/>━━━━━━━<br/>Pipeline Tracking<br/>Type: Design/Test<br/>Training/Event<br/>Value, Stage"]
  
  Menu --> Engagement["🤝 ENGAGEMENTS<br/>━━━━━━━<br/>Unified Object<br/>Design/Test<br/>Training/Event<br/>Budget, Owner"]
  
  Menu --> Interaction["💬 INTERACTIONS<br/>━━━━━━━<br/>Meeting Notes<br/>Call Logs<br/>Email Tracking<br/>Approval History"]
  
  Menu --> Task["✅ TASKS<br/>━━━━━━━<br/>Task Management<br/>Assignment<br/>Status Tracking<br/>Kanban/Calendar"]
  
  Menu --> Activity["📊 ACTIVITY LOG<br/>━━━━━━━<br/>Timeline<br/>User Actions<br/>Audit Trail<br/>Export Reports"]
  
  Menu --> Notification["🔔 NOTIFICATIONS<br/>━━━━━━━<br/>In-app Alerts<br/>Email Digest<br/>Real-time Updates<br/>Subscribe/Manage"]
  
  Org --> OrgActions["➕ Add Organization<br/>✏️ Edit Details<br/>👥 Add Contacts<br/>📊 View Pipeline<br/>💰 View Revenue<br/>📅 View Timeline<br/>🗑️ Archive"]
  
  Contact --> ContactActions["➕ Add Contact<br/>✏️ Edit Profile<br/>🏷️ Add Tags<br/>📞 Log Interaction<br/>📋 View Engagements<br/>📧 Send Email<br/>📊 View History"]
  
  Opportunity --> OppActions["➕ Create Opportunity<br/>✏️ Update Stage<br/>💰 Update Value<br/>📎 Link to Contact<br/>📄 Attach Documents<br/>✅ Mark Closed<br/>🔄 Convert to Engagement"]
  
  Engagement --> EngActions["➕ Create Engagement<br/>✏️ Update Status<br/>💰 Set Budget<br/>👥 Assign Team<br/>📅 Set Dates<br/>🎨 Link to Design/Test<br/>📊 View Financials"]
  
  Interaction --> IntActions["➕ Add Note<br/>📞 Log Meeting<br/>✉️ Log Email<br/>👥 Add Participants<br/>📎 Attach Files<br/>✏️ Edit Note<br/>🗑️ Delete"]
  
  Task --> TaskActions["➕ Create Task<br/>✏️ Edit Details<br/>👥 Assign Owner<br/>🎯 Change Priority<br/>✅ Mark Done<br/>🔄 Reorder<br/>📋 Link to Engagement"]
  
  Activity --> ActivityActions["📊 View Timeline<br/>🔍 Filter Events<br/>📤 Export Log<br/>👤 View by User<br/>📌 Pin Important<br/>🔎 Search Events"]
  
  Notification --> NotifActions["🔔 View All<br/>✅ Mark Read<br/>⭐ Prioritize<br/>🔗 View Source<br/>📧 Email Settings<br/>⚙️ Notification Prefs"]
  
  OrgActions --> Export["📤 EXPORT & SHARE<br/>━━━━━━━<br/>Export CSV<br/>Share Link<br/>Print Report"]
  
  ContactActions --> Export
  OppActions --> Export
  EngActions --> Export
  IntActions --> Export
  TaskActions --> Export
  ActivityActions --> Export
  NotifActions --> Export
  
  Export --> Logout["🚪 LOGOUT"]
  Logout --> End2(["End Session"])
  
