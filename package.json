{
  "name": "print-shop",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "diagrams:build": "chmod +x @data/diagrams/build-diagrams.sh && @data/diagrams/build-diagrams.sh all",
    "diagrams:build:svg": "chmod +x @data/diagrams/build-diagrams.sh && @data/diagrams/build-diagrams.sh svg",
    "diagrams:build:pdf": "chmod +x @data/diagrams/build-diagrams.sh && @data/diagrams/build-diagrams.sh pdf",
    "diagrams:build:png": "chmod +x @data/diagrams/build-diagrams.sh && @data/diagrams/build-diagrams.sh png",
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev",
    "dev:prod-mode": "NEXT_PUBLIC_DEV_MODE=false next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:prod": "NODE_ENV=production prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:reset:push": "prisma db push --force-reset",
    "db:reset:prod": "NODE_ENV=production prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:deploy": "prisma migrate deploy",
    "test:email": "node scripts/test-email.mjs",
    "test:welcome-email": "node scripts/test-welcome-email.mjs",
    "test:create-user": "node scripts/create-test-user.mjs",
    "test:forgot-password": "node scripts/test-forgot-password.mjs",
    "generate:2fa-key": "node scripts/generate-2fa-key.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "pnpm test:integration && pnpm test:e2e",
    "format": "pnpm format-app && pnpm format-prisma && pnpm format-lib && pnpm format-component && pnpm format-imports",
    "format-app": "prettier 'app/**/*.{ts,json,tsx,css,js,scss,yaml}' --use-tabs --tab-width 4 --bracket-same-line --prose-wrap always --print-width 1000 --write",
    "format-lib": "prettier 'lib/**/*.{ts,json,tsx,css,js,scss,yaml}' --use-tabs --tab-width 4 --bracket-same-line --prose-wrap always --print-width 1000 --write",
    "format-prisma": "prettier 'prisma/**/*.{ts,json,tsx,css,js,scss,yaml}' --use-tabs --tab-width 4 --bracket-same-line --prose-wrap always --print-width 1000 --write",
    "format-component": "prettier 'components/**/*.{ts,json,tsx,css,js,scss,yaml}' --use-tabs --tab-width 4 --bracket-same-line --prose-wrap always --print-width 1000 --write",
    "format-imports": "eslint 'app/**/*.{ts,tsx}' 'lib/**/*.{ts,tsx}' 'components/**/*.{ts,tsx}' --fix --config eslint.config.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MadeLabDev/madeapp.git"
  },
